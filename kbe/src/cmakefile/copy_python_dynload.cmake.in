set(py_build_dir "@PYTHON_BUILD_DIR@")
set(py_src_dir "@PYTHON_SRC_DIR@")
set(dst "@RES_SCRIPTS_DIR@/lib-dynload")

file(GLOB _platlib_dirs "${py_build_dir}/lib.*")

set(src "")
foreach(_platlib IN LISTS _platlib_dirs)
  if(EXISTS "${_platlib}/lib-dynload")
    set(src "${_platlib}/lib-dynload")
    break()
  endif()
endforeach()

file(REMOVE_RECURSE "${dst}")
file(MAKE_DIRECTORY "${dst}")

if(NOT src STREQUAL "")
  file(COPY "${src}/" DESTINATION "${dst}")
else()
  file(GLOB _module_sos "${py_src_dir}/Modules/*.so")
  if(_module_sos)
    file(COPY ${_module_sos} DESTINATION "${dst}")
    list(LENGTH _module_sos _module_count)
    message(STATUS "Python lib-dynload not found; copied ${_module_count} extension modules from ${py_src_dir}/Modules")
  else()
    message(STATUS "Python extension modules not found; created empty directory: ${dst}")
  endif()
endif()
